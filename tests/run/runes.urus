rune square(x) { x * x }
rune add(a, b) { a + b }
rune double_it(x) { x + x }
rune cube(x) { x * x * x }
rune sum3(a, b, c) { a + b + c }

fn main(): void {
    print(square!(5));
    print(square!(3));
    print(add!(100, 200));
    print(double_it!(7));
    print(cube!(3));
    print(sum3!(10, 20, 30));

    let x: int = square!(4);
    print(x);

    let y: int = add!(square!(3), 1);
    print(y);
}
