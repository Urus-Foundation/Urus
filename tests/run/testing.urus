fn add(a: int, b: int): int {
    return a + b;
}

fn double(x: int): int {
    return x * 2;
}

test "addition works" {
    assert_eq(add(2, 3), 5);
    assert_eq(add(-1, 1), 0);
    assert_eq(add(0, 0), 0);
}

test "double function" {
    assert_eq(double(5), 10);
    assert_eq(double(0), 0);
    assert_ne(double(3), 5);
}

test "string operations" {
    assert_eq(str_upper("hello"), "HELLO");
    assert_eq(str_len("abc"), 3);
    assert_ne("hello", "world");
}

test "boolean checks" {
    assert_eq(true, true);
    assert_ne(true, false);
}

fn main(): void {
    print("normal mode");
}
