import graph;

fn main(): void {
    // Bar chart
    let labels: [str] = ["Apple", "Banana", "Cherry"];
    let values: [float] = [30.0, 50.0, 20.0];
    graph_bar(labels, values, 20);

    print("---");

    // Line chart
    let line_data: [float] = [1.0, 3.0, 2.0, 5.0, 4.0];
    graph_line(line_data, 5);

    print("---");

    // Histogram
    let hist_data: [float] = [1.0, 1.5, 2.0, 2.5, 2.5, 3.0, 3.5, 4.0, 4.5, 5.0];
    graph_histogram(hist_data, 4);

    print("---");

    // Sparkline
    let spark: str = graph_sparkline(line_data);
    print(spark);
}
