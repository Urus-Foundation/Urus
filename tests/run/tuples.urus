fn get_pair(): (int, str) {
    return (42, "hello");
}

fn use_tuple(t: (int, float)): void {
    print(t.0);
    print(t.1);
}

fn main(): void {
    let t: (int, float) = (1, 3.14);
    print(t.0);
    print(t.1);

    let p: (int, str) = get_pair();
    print(p.0);
    print(p.1);

    use_tuple((10, 2.5));

    let triple: (int, int, int) = (100, 200, 300);
    print(triple.0);
    print(triple.1);
    print(triple.2);
}
